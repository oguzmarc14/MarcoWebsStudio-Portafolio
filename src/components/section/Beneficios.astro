---
import { benefitItems } from '../../data/landing';
import SectionHeading from '../ui/SectionHeading.astro';
---

<section id="beneficios" class="relative px-4 py-24 sm:px-6 lg:px-8" data-reveal>
	<div class="mx-auto max-w-7xl">
		<SectionHeading
			eyebrow="Beneficios"
			title="Una página que se ve bien, carga rápido y ayuda a cerrar más clientes."
			description="La experiencia visual acompaña el mensaje comercial para que tu negocio no solo se vea moderno, sino también confiable y útil."
		/>

		<div class="grid gap-5 md:grid-cols-2 xl:grid-cols-5">
			{benefitItems.map((item) => (
				<article class="premium-surface group rounded-2xl bg-white/5 p-5" data-reveal style="--reveal-delay: 90ms;">
					<div class="flex h-12 w-12 items-center justify-center rounded-2xl border border-cyan-400/15 bg-cyan-400/10 text-cyan-200 transition group-hover:scale-105 group-hover:bg-cyan-400/15">
						<i class={`fa-solid ${item.icon}`}></i>
					</div>
					<h3 class="mt-5 text-lg font-semibold text-white">{item.title}</h3>
					<p class="mt-2 text-sm leading-6 text-slate-300">{item.description}</p>
				</article>
			))}
		</div>
	</div>
</section>