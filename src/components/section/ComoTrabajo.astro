---
import { processSteps } from '../../data/landing';
import SectionHeading from '../ui/SectionHeading.astro';
---

<section class="relative px-4 py-24 sm:px-6 lg:px-8" data-reveal>
	<div class="mx-auto max-w-7xl">
		<SectionHeading
			eyebrow="Cómo trabajo"
			title="Un proceso claro, ordenado y enfocado en resultados."
			description="Cada etapa reduce fricción y acelera la publicación de una web lista para vender."
		/>

		<div class="grid gap-5 lg:grid-cols-4">
			{processSteps.map((step, index) => (
				<article class="premium-surface relative rounded-2xl bg-white/5 p-6" data-reveal style={`--reveal-delay: ${index * 80}ms;`}>
					<div class="absolute right-4 top-4 text-6xl font-semibold text-cyan-400/10">0{index + 1}</div>
					<div class="flex h-12 w-12 items-center justify-center rounded-2xl border border-cyan-400/15 bg-cyan-400/10 text-cyan-200">
						<i class="fa-solid fa-check"></i>
					</div>
					<h3 class="mt-5 text-xl font-semibold text-white">{step.title}</h3>
					<p class="mt-3 text-sm leading-6 text-slate-300">{step.description}</p>
				</article>
			))}
		</div>
	</div>
</section>