---
import { processSteps } from '../../data/landing';
import SectionHeading from '../ui/SectionHeading.astro';

const stepIcons = ['fa-magnifying-glass', 'fa-pen-ruler', 'fa-code', 'fa-rocket'];
---

<section class="relative px-4 py-16 sm:py-20 sm:px-6 lg:px-8 lg:py-28">

    <!-- Ambient -->
    <div class="pointer-events-none absolute right-0 top-1/3 hidden sm:block h-[20rem] w-[20rem] sm:h-[28rem] sm:w-[28rem] lg:h-[35rem] lg:w-[35rem] rounded-full opacity-20"
        style="background: radial-gradient(circle, rgba(34,211,238,0.07), transparent 65%); filter: blur(80px);"></div>

    <div class="relative mx-auto max-w-7xl">
        <SectionHeading
            eyebrow="Cómo trabajo"
            title="Un proceso claro, ordenado y enfocado en resultados."
            description="Cada etapa reduce fricción y acelera la publicación de una web lista para vender."
        />

        <!-- Steps -->
        <div class="relative grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">

            <!-- Connector line (desktop only) -->
            <div class="pointer-events-none absolute left-0 right-0 top-8 hidden h-px lg:block"
                style="background: linear-gradient(90deg, transparent 4%, rgba(34,211,238,0.2) 15%, rgba(34,211,238,0.2) 85%, transparent 96%); margin: 0 calc(12.5% + 1.5rem);"></div>

            {processSteps.map((step, index) => (
                <article
                    class="group relative overflow-hidden rounded-2xl p-4 sm:p-6 transition-all duration-500 hover:-translate-y-2"
                    data-reveal
                    style={`background: linear-gradient(160deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0.02) 100%); border: 1px solid rgba(255,255,255,0.07); backdrop-filter: blur(20px); --reveal-delay: ${index * 100}ms;`}>
                >
                    <!-- Hover glow -->
                    <div class="pointer-events-none absolute inset-0 rounded-2xl opacity-0 transition-opacity duration-500 group-hover:opacity-100"
                        style="background: radial-gradient(circle at 50% 0%, rgba(34,211,238,0.07), transparent 60%);"></div>

                    <!-- Bottom accent -->
                    <div class="absolute bottom-0 left-0 h-px w-0 rounded-full transition-all duration-500 group-hover:w-full"
                        style="background: linear-gradient(90deg, transparent, rgba(34,211,238,0.4), transparent);"></div>

                    <!-- Step number badge (connects with line) -->
                    <div class="relative mb-5 flex h-8 w-8 sm:h-10 sm:w-10 items-center justify-center rounded-xl transition-all duration-300 group-hover:scale-110"
                        style="background: linear-gradient(135deg, rgba(34,211,238,0.14), rgba(6,182,212,0.05)); border: 1px solid rgba(34,211,238,0.22); box-shadow: 0 0 24px rgba(34,211,238,0.1);">
                        <i class={`fa-solid ${stepIcons[index]} text-cyan-300 text-xs sm:text-sm`}></i>
                    </div>

                    <!-- Watermark number -->
                    <div class="pointer-events-none absolute right-4 top-4 font-black text-white/[0.04] text-4xl sm:text-6xl leading-none select-none hidden sm:block">
                        {index + 1}
                    </div>

                    <p class="mb-1 font-mono text-[10px] font-bold uppercase tracking-[0.25em] text-cyan-400/50">Paso {index + 1}</p>
                    <h3 class="text-base font-bold text-white group-hover:text-cyan-50 transition-colors">{step.title}</h3>
                    <p class="mt-2 text-sm leading-6 text-slate-400">{step.description}</p>
                </article>
            ))}
        </div>
    </div>
</section>