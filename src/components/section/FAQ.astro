---
import { faqItems } from '../../data/landing';
import SectionHeading from '../ui/SectionHeading.astro';
---

<section id="faq" class="relative px-4 py-28 sm:px-6 lg:px-8">

    <div class="pointer-events-none absolute left-1/2 top-1/2 h-[35rem] w-[40rem] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-20"
        style="background: radial-gradient(circle, rgba(34,211,238,0.06), transparent 65%); filter: blur(90px);"></div>

    <div class="relative mx-auto max-w-7xl">
        <div class="grid gap-16 lg:grid-cols-[1fr_1.4fr] lg:items-start">

            <!-- Left: heading -->
            <div class="lg:sticky lg:top-32">
                <SectionHeading
                    eyebrow="Preguntas frecuentes"
                    title="Respuestas rápidas antes de cotizar."
                    description="Las dudas principales están resueltas aquí para que el proceso sea más claro desde el inicio."
                />
            </div>

            <!-- Right: accordion list -->
            <div class="space-y-3" data-reveal style="--reveal-delay: 80ms;">
                {faqItems.map((item, i) => (
                    <details class="faq-item group relative overflow-hidden rounded-2xl transition-all duration-400"
                        style="background: linear-gradient(160deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%); border: 1px solid rgba(255,255,255,0.07);"
                        data-reveal
                        style={`--reveal-delay: ${i * 70}ms;`}
                    >
                        <!-- Left accent bar -->
                        <div class="absolute left-0 top-0 h-0 w-0.5 rounded-full transition-all duration-500 group-open:h-full"
                            style="background: linear-gradient(180deg, transparent, rgba(34,211,238,0.7), transparent);"></div>

                        <!-- Hover/open glow -->
                        <div class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-400 group-open:opacity-100"
                            style="background: linear-gradient(90deg, rgba(34,211,238,0.05) 0%, transparent 50%);"></div>

                        <summary class="relative flex cursor-pointer list-none select-none items-center justify-between gap-4 px-6 py-5 text-left">
                            <span class="text-base font-bold text-white/90 transition-colors group-open:text-cyan-100">{item.question}</span>
                            <div class="flex-shrink-0 flex h-8 w-8 items-center justify-center rounded-lg transition-all duration-300 group-open:rotate-45 group-open:bg-cyan-400/15"
                                style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);">
                                <i class="fa-solid fa-plus text-xs text-cyan-300/80"></i>
                            </div>
                        </summary>

                        <p class="relative px-6 pb-5 text-sm leading-7 text-slate-400">{item.answer}</p>
                    </details>
                ))}
            </div>
        </div>
    </div>
</section>