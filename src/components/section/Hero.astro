---
import { whatsappUrl } from '../../data/landing';
---

<header id="home" class="relative overflow-hidden pt-28 sm:pt-32">

    <!-- ── HERO BACKGROUND LAYERS ──────────────────────── -->

    <!-- Base gradient -->
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 90% 65% at 50% 0%, rgba(34,211,238,0.13), transparent 55%), linear-gradient(180deg, #050816 0%, #080f1f 60%, #0f172a 100%);"></div>

    <!-- Hero image overlay -->
    <div class="absolute inset-0 bg-[url('/fondo-hero.webp')] bg-cover bg-center opacity-[0.14] mix-blend-screen"></div>

    <!-- Grid futurista -->
    <div class="pointer-events-none absolute inset-0 opacity-50"
        style="background-image: linear-gradient(rgba(148,163,184,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(148,163,184,0.05) 1px, transparent 1px); background-size: 72px 72px; mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black, transparent);"></div>

    <!-- Dot matrix -->
    <div class="pointer-events-none absolute inset-0 opacity-[0.06] mix-blend-screen"
        style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.9) 1px, transparent 0); background-size: 28px 28px;"></div>

    <!-- Aurora blobs (hidden on small screens) -->
    <div class="hidden sm:block pointer-events-none absolute -left-32 top-20 h-[38rem] w-[38rem] rounded-full animate-aurora"
        style="background: radial-gradient(circle, rgba(34,211,238,0.13), transparent 65%); filter: blur(80px);"></div>
    <div class="hidden sm:block pointer-events-none absolute -right-24 top-10 h-[36rem] w-[36rem] rounded-full animate-aurora-alt"
        style="background: radial-gradient(circle, rgba(6,182,212,0.1), transparent 65%); filter: blur(100px);"></div>
    <div class="hidden sm:block pointer-events-none absolute left-1/2 -translate-x-1/2 top-0 h-[50rem] w-[60rem] rounded-full animate-pulse-glow"
        style="background: radial-gradient(circle, rgba(34,211,238,0.08), transparent 55%); filter: blur(120px);"></div>

    <!-- Scan line -->
    <div class="pointer-events-none absolute inset-x-0 top-0 h-px w-full animate-scan"
        style="background: linear-gradient(90deg, transparent, rgba(34,211,238,0.6), transparent);"></div>

    <!-- Floating particles (hide on small screens) -->
    <div class="hidden sm:block pointer-events-none absolute inset-0 overflow-hidden">
        <div class="particle" style="left:12%; top:18%; animation-delay:0s;"></div>
        <div class="particle" style="left:27%; top:65%; animation-delay:1.2s;"></div>
        <div class="particle" style="left:55%; top:22%; animation-delay:2.4s;"></div>
        <div class="particle" style="left:73%; top:55%; animation-delay:0.8s;"></div>
        <div class="particle" style="left:88%; top:30%; animation-delay:3.1s;"></div>
        <div class="particle" style="left:42%; top:80%; animation-delay:1.9s;"></div>
        <div class="particle-lg" style="left:6%; top:45%; animation-delay:0.5s;"></div>
        <div class="particle-lg" style="left:92%; top:70%; animation-delay:2.8s;"></div>
    </div>

    <!-- ── SPOTLIGHT SECTION ───────────────────────────── -->
    <section
        id="hero-spotlight"
        class="relative mx-auto max-w-7xl overflow-hidden px-4 pb-28 sm:px-6 lg:px-8"
        style="--x: 50%; --y: 30%;"
    >
        <!-- Mouse spotlight -->
        <div class="spotlight pointer-events-none absolute inset-0" aria-hidden="true"></div>

        <!-- Top fade -->
        <div class="absolute inset-x-0 top-0 h-24 bg-gradient-to-b from-[#050816] to-transparent"></div>

        <!-- ── CONTENT GRID ─────────────────────────────── -->
        <div class="relative grid items-center gap-16 lg:grid-cols-[1.1fr_0.9fr] lg:gap-12">

            <!-- Left: Copy -->
            <div class="space-y-8 py-14 sm:py-18 lg:py-24">

                <!-- Eyebrow chip -->
                <div class="premium-chip inline-flex items-center gap-2.5 rounded-full px-5 py-2.5 text-xs font-semibold uppercase tracking-[0.3em] text-cyan-100/90 animate-pulse-glow" data-reveal style="--reveal-delay: 0ms;">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping-slow absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
                        <span class="relative inline-flex h-2 w-2 rounded-full bg-cyan-400"></span>
                    </span>
                    Disponible para nuevos proyectos
                </div>

                <!-- Main headline -->
                <div class="space-y-4" data-reveal style="--reveal-delay: 100ms;">
                    <h1 class="text-5xl font-bold leading-[1.05] tracking-tight text-white sm:text-6xl lg:text-7xl xl:text-8xl">
                        <span class="gradient-text-subtle">Páginas web</span>
                        <br />
                        <span class="glow-text text-white">que venden</span>
                        <br />
                        <span class="gradient-text">más.</span>
                    </h1>
                </div>

                <!-- Description -->
                <p class="max-w-lg text-base leading-8 text-slate-300/90 sm:text-lg" data-reveal style="--reveal-delay: 180ms;">
                    Diseño sitios elegantes, rápidos y enfocados en conversión para negocios que necesitan destacar y convertir visitas en clientes reales.
                </p>

                <!-- CTA Buttons -->
                <div class="flex flex-col gap-4 sm:flex-row" data-reveal style="--reveal-delay: 260ms;">
                    <a href={whatsappUrl}
                        class="premium-button inline-flex items-center justify-center gap-3 rounded-2xl px-7 py-4 text-base font-bold">
                        <i class="fa-brands fa-whatsapp text-xl"></i>
                        Cotizar por WhatsApp
                    </a>
                    <a href="#proyectos"
                        class="premium-button-secondary inline-flex items-center justify-center gap-3 rounded-2xl px-7 py-4 text-base font-semibold">
                        Ver proyectos
                        <i class="fa-solid fa-arrow-right text-xs text-cyan-300"></i>
                    </a>
                </div>

                <!-- Mini stats -->
                <div class="grid grid-cols-3 gap-4 border-t border-white/5 pt-8" data-reveal style="--reveal-delay: 340ms;">
                    {[
                        { value: '+15', label: 'Proyectos entregados' },
                        { value: '< 2s', label: 'Tiempo de carga' },
                        { value: '100%', label: 'Responsive' },
                    ].map((stat) => (
                        <div class="space-y-1">
                            <p class="text-2xl font-bold text-white glow-text-subtle sm:text-3xl">{stat.value}</p>
                            <p class="text-xs text-slate-400 leading-tight">{stat.label}</p>
                        </div>
                    ))}
                </div>
            </div>

            <!-- Right: Premium card mockup -->
            <div class="relative mx-auto w-full max-w-lg" data-reveal style="--reveal-delay: 160ms;">

                <!-- Glow blob behind card -->
                <div class="pointer-events-none absolute inset-0 -m-8 rounded-full animate-pulse-glow"
                    style="background: radial-gradient(circle, rgba(34,211,238,0.2), transparent 60%); filter: blur(60px);"></div>

                <!-- Main card -->
                <div class="premium-surface relative rounded-[1.75rem] p-5 sm:p-6">
                    <!-- Inner shine -->
                    <div class="pointer-events-none absolute inset-0 rounded-[1.75rem] opacity-60"
                        style="background: linear-gradient(135deg, rgba(255,255,255,0.07) 0%, transparent 30%, transparent 70%, rgba(255,255,255,0.04) 100%);"></div>

                    <!-- Card Header -->
                    <div class="flex items-center justify-between border-b border-white/8 pb-4">
                        <div>
                            <p class="text-[10px] font-semibold uppercase tracking-[0.35em] text-cyan-300/70">Presencia digital</p>
                            <p class="mt-1.5 text-xl font-bold text-white">Marco Webs Studio</p>
                        </div>
                        <div class="flex items-center gap-2 rounded-full border border-cyan-400/25 bg-cyan-400/10 px-3 py-1.5 text-xs font-semibold text-cyan-200"
                            style="box-shadow: 0 0 20px rgba(34,211,238,0.12);">
                            <span class="relative flex h-2 w-2">
                                <span class="animate-ping-slow absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                                <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-400"></span>
                            </span>
                            Disponible
                        </div>
                    </div>

                    <!-- Card body: 2 mini cards -->
                    <div class="grid gap-3 py-4 sm:grid-cols-2">
                        <div class="premium-surface rounded-2xl bg-[#050816]/50 p-4">
                            <p class="text-xs font-medium text-slate-400">Diseño web</p>
                            <p class="mt-2 text-lg font-bold text-white leading-tight">Diseño + estrategia</p>
                            <p class="mt-2 text-xs leading-5 text-slate-400">Visual premium con foco en conversión.</p>
                        </div>
                        <div class="premium-surface rounded-2xl bg-[#050816]/50 p-4">
                            <p class="text-xs font-medium text-slate-400">WhatsApp listo</p>
                            <p class="mt-2 text-lg font-bold text-white leading-tight">Cotizaciones directas</p>
                            <p class="mt-2 text-xs leading-5 text-slate-400">Cierre sin fricción desde el primer clic.</p>
                        </div>
                    </div>

                    <!-- Tags -->
                    <div class="grid grid-cols-3 gap-2 border-t border-white/8 pt-4 text-xs">
                        {['Negocios locales', 'Branding moderno', 'Resultados reales'].map((tag) => (
                            <div class="premium-tag rounded-xl p-2.5 text-center font-medium text-slate-200 text-[11px]">{tag}</div>
                        ))}
                    </div>

                    <!-- Bottom tech bar -->
                    <div class="mt-4 flex items-center justify-between rounded-xl border border-white/5 bg-white/3 px-4 py-3">
                        <span class="text-[10px] font-medium uppercase tracking-widest text-slate-500">Tech stack</span>
                        <div class="flex items-center gap-3 text-slate-400 text-xs font-medium">
                            <span class="text-cyan-400/80">Astro</span>
                            <span class="h-px w-3 bg-white/10"></span>
                            <span class="text-sky-400/80">Tailwind</span>
                            <span class="h-px w-3 bg-white/10"></span>
                            <span class="text-blue-400/80">TypeScript</span>
                        </div>
                    </div>
                </div>

                <!-- Decorative corner glow -->
                <div class="pointer-events-none absolute -bottom-6 -right-6 h-32 w-32 rounded-full"
                    style="background: radial-gradient(circle, rgba(34,211,238,0.15), transparent 70%); filter: blur(24px);"></div>
            </div>
        </div>
    </section>

    <!-- Bottom fade -->
    <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-[#050816] to-transparent"></div>

    <script>
        // Only attach mousemove spotlight on devices with a precise pointer
        if (window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
            const hero = document.querySelector<HTMLElement>('#hero-spotlight');
            const spotlight = hero?.querySelector<HTMLElement>('.spotlight');

            if (hero && spotlight) {
                const update = (e) => {
                    const b = hero.getBoundingClientRect();
                    const x = e.clientX - b.left;
                    const y = e.clientY - b.top;
                    spotlight.style.background = `radial-gradient(600px circle at ${x}px ${y}px, rgba(34,211,238,0.12), rgba(34,211,238,0.04) 30%, transparent 65%)`;
                };
                const reset = () => {
                    spotlight.style.background = 'radial-gradient(600px circle at 50% 30%, rgba(34,211,238,0.07), transparent 65%)';
                };
                reset();
                hero.addEventListener('mousemove', update, { passive: true });
                hero.addEventListener('mouseleave', reset);
            }
        }
    </script>
</header>

<style>
    .particle {
        position: absolute;
        width: 3px;
        height: 3px;
        border-radius: 50%;
        background: rgba(103, 232, 249, 0.7);
        box-shadow: 0 0 8px rgba(34, 211, 238, 0.8);
        animation: float 8s ease-in-out infinite;
    }

    .particle-lg {
        position: absolute;
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: rgba(34, 211, 238, 0.5);
        box-shadow: 0 0 14px rgba(34, 211, 238, 0.6);
        animation: float 12s ease-in-out infinite reverse;
    }

    @keyframes float {
        0%, 100% { transform: translateY(0px) scale(1); opacity: 0.7; }
        50% { transform: translateY(-18px) scale(1.2); opacity: 1; }
    }
</style>
