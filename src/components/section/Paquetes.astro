---
import { packageItems } from '../../data/landing';
import SectionHeading from '../ui/SectionHeading.astro';
---

<section id="paquetes" class="relative px-4 py-24 sm:px-6 lg:px-8" data-reveal>
	<div class="mx-auto max-w-7xl">
		<SectionHeading
			eyebrow="Paquetes"
			title="Opciones pensadas para distintos niveles de negocio."
			description="Elige una base clara y escalable. Si tu proyecto necesita algo más específico, también se puede ajustar."
		/>

		<div class="grid gap-6 xl:grid-cols-3">
			{packageItems.map((item) => (
				<article class:list={['premium-surface relative rounded-2xl p-6 transition hover:-translate-y-1', item.featured ? 'premium-surface-strong bg-cyan-400/10' : 'bg-white/5']} data-reveal style="--reveal-delay: 90ms;">
					{item.featured && <div class="premium-button absolute right-4 top-4 rounded-full px-3 py-1 text-xs font-semibold">Más solicitado</div>}
					<p class="text-sm font-medium uppercase tracking-[0.28em] text-cyan-200/70">{item.title}</p>
					<p class="mt-3 text-3xl font-semibold text-white">{item.price}</p>
					<p class="mt-3 text-slate-300">{item.description}</p>
					<ul class="mt-6 space-y-3 text-sm text-slate-200">
						{item.includes.map((include) => (
							<li class="flex items-center gap-3">
								<span class="flex h-6 w-6 items-center justify-center rounded-full bg-emerald-400/15 text-emerald-300">
									<i class="fa-solid fa-check text-[10px]"></i>
								</span>
								{include}
							</li>
						))}
					</ul>
				</article>
			))}
		</div>
	</div>
</section>