---
import { projectItems } from '../../data/landing';
import SectionHeading from '../ui/SectionHeading.astro';
---

<section id="proyectos" class="relative px-4 py-24 sm:px-6 lg:px-8" data-reveal>
	<div class="mx-auto max-w-7xl">
		<SectionHeading
			eyebrow="Proyectos destacados"
			title="Trabajo reciente con enfoque en conversión y presencia premium."
			description="Cada proyecto busca claridad, confianza visual y una ruta directa para que el negocio reciba contactos reales."
		/>

		<div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
			{projectItems.map((project) => (
				<article class="premium-surface group overflow-hidden rounded-2xl bg-white/5 p-4" data-reveal style="--reveal-delay: 90ms;">
					<div class="relative overflow-hidden rounded-2xl border border-white/10">
						<img src={project.image} alt={project.alt} class="h-56 w-full object-cover transition duration-500 group-hover:scale-[1.04]" />
						<div class="absolute inset-0 bg-linear-to-t from-[#050816] via-transparent to-transparent"></div>
					</div>

					<div class="space-y-4 p-3 pt-5">
						<div class="flex flex-wrap gap-2">
							{project.badges.map((badge) => (
								<span class="premium-tag rounded-full px-3 py-1 text-xs font-medium text-cyan-100">{badge}</span>
							))}
						</div>

						<div class="space-y-2">
							<h3 class="text-xl font-semibold text-white">{project.title}</h3>
							<p class="text-sm leading-6 text-slate-300">{project.description}</p>
						</div>

						<a href={project.href} class="premium-button-secondary inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold text-white">
							Ver proyecto
							<i class="fa-solid fa-arrow-right text-xs text-cyan-200"></i>
						</a>
					</div>
				</article>
			))}
		</div>
	</div>
</section>

