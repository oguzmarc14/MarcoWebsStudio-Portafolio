---
import { serviceItems } from '../../data/landing';
import SectionHeading from '../ui/SectionHeading.astro';

const serviceIcons = [
    'fa-file-code',
    'fa-globe',
    'fa-table-list',
    'fa-building',
    'fa-rotate',
];

const serviceDescriptions = [
    'Una página enfocada en convertir visitas en contactos directos para tu negocio.',
    'Sitio completo con múltiples secciones, branding y diseño premium.',
    'Muestra tus productos o servicios de forma clara y moderna.',
    'Sitio especializado para captar leads de propiedades y terrenos.',
    'Dale vida nueva a tu página antigua con diseño moderno y conversión.',
];
---

<section id="servicios" class="relative px-4 py-28 sm:px-6 lg:px-8">

    <!-- Ambient glow -->
    <div class="pointer-events-none absolute right-0 top-1/2 h-[40rem] w-[30rem] -translate-y-1/2 rounded-full opacity-20"
        style="background: radial-gradient(circle, rgba(34,211,238,0.08), transparent 65%); filter: blur(80px);"></div>

    <div class="relative mx-auto max-w-7xl">

        <div class="grid gap-16 lg:grid-cols-[1fr_1.5fr] lg:items-start">

            <!-- Left: Heading + description -->
            <div class="lg:sticky lg:top-32">
                <SectionHeading
                    eyebrow="Servicios"
                    title="Soluciones que presentan, conectan y convierten."
                    description="Cada servicio está diseñado para un tipo de negocio y objetivo comercial específico."
                />

                <!-- Visual accent -->
                <div class="mt-8 space-y-3">
                    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-slate-500">Proceso incluido</p>
                    {['Análisis de negocio', 'Diseño visual premium', 'Desarrollo responsive', 'Publicación y WhatsApp'].map((step, i) => (
                        <div class="flex items-center gap-3 text-sm text-slate-400">
                            <span class="flex h-5 w-5 items-center justify-center rounded-full text-[10px] font-bold text-cyan-400"
                                style="background: rgba(34,211,238,0.1); border: 1px solid rgba(34,211,238,0.2);">
                                {i + 1}
                            </span>
                            {step}
                        </div>
                    ))}
                </div>
            </div>

            <!-- Right: Service list -->
            <div class="space-y-3">
                {serviceItems.map((service, index) => (
                    <div
                        class="service-item group relative overflow-hidden rounded-2xl px-6 py-5 transition-all duration-400 cursor-default"
                        style="background: linear-gradient(160deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%); border: 1px solid rgba(255,255,255,0.07); backdrop-filter: blur(20px);"
                        data-reveal
                        style={`--reveal-delay: ${index * 80}ms;`}
                    >
                        <!-- Left glow bar -->
                        <div class="absolute left-0 top-0 h-full w-0.5 rounded-full opacity-0 transition-opacity duration-400 group-hover:opacity-100"
                            style="background: linear-gradient(180deg, transparent, rgba(34,211,238,0.7), transparent);"></div>

                        <!-- Background glow -->
                        <div class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-400 group-hover:opacity-100"
                            style="background: linear-gradient(90deg, rgba(34,211,238,0.06) 0%, transparent 60%);"></div>

                        <div class="relative flex items-start justify-between gap-6">
                            <!-- Number + text -->
                            <div class="flex items-start gap-5">
                                <span class="mt-0.5 font-mono text-xs font-bold text-cyan-400/50 transition-colors group-hover:text-cyan-400">
                                    {String(index + 1).padStart(2, '0')}
                                </span>
                                <div>
                                    <h3 class="text-base font-bold text-white/90 transition-colors group-hover:text-white">{service}</h3>
                                    <p class="mt-1.5 text-sm leading-6 text-slate-500 transition-colors group-hover:text-slate-400">
                                        {serviceDescriptions[index]}
                                    </p>
                                </div>
                            </div>

                            <!-- Icon -->
                            <div class="flex-shrink-0 flex h-10 w-10 items-center justify-center rounded-xl transition-all duration-300 group-hover:scale-110 group-hover:rotate-3"
                                style="background: rgba(34,211,238,0.08); border: 1px solid rgba(34,211,238,0.15);">
                                <i class={`fa-solid ${serviceIcons[index]} text-cyan-400/70 text-sm transition-colors group-hover:text-cyan-300`}></i>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>