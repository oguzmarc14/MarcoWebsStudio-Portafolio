---
import { navLinks, whatsappUrl } from '../../data/landing';
---

<nav id="main-navbar" class="fixed inset-x-0 top-0 z-50 px-3 pt-3 sm:px-6 sm:pt-4 animate-fade-in">
    <div class="navbar-inner mx-auto flex max-w-7xl items-center justify-between rounded-2xl px-3 py-2.5 sm:px-4 sm:py-3 transition-all duration-500"
        style="background: rgba(5,8,22,0.6); backdrop-filter: blur(20px) saturate(1.5); border: 1px solid rgba(255,255,255,0.07); box-shadow: 0 8px 32px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.05);">

        <!-- Logo -->
        <a href="#home" class="group flex items-center gap-3 text-white">
            <div class="relative flex h-9 w-9 items-center justify-center rounded-xl"
                style="background: linear-gradient(135deg, rgba(34,211,238,0.15), rgba(6,182,212,0.05)); border: 1px solid rgba(34,211,238,0.25); box-shadow: 0 0 20px rgba(34,211,238,0.12);">
                <span class="text-xs font-bold tracking-tight text-cyan-200">MW</span>
                <!-- Ping indicator -->
                <span class="absolute -right-0.5 -top-0.5 flex h-2.5 w-2.5">
                    <span class="animate-ping-slow absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-60"></span>
                    <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-cyan-400"></span>
                </span>
            </div>
            <span class="text-sm font-semibold tracking-wide text-white/90 transition group-hover:text-white sm:text-sm max-[360px]:hidden">Marco Webs Studio</span>
        </a>

        <!-- Nav Links -->
        <div class="hidden items-center gap-6 text-sm md:flex">
            {navLinks.map((item) => (
                <a class="nav-link relative text-slate-300/80 transition-colors duration-200 hover:text-white" href={item.href}>
                    {item.label}
                    <span class="absolute -bottom-0.5 left-0 h-px w-0 rounded-full bg-cyan-400 transition-all duration-300 group-hover:w-full nav-underline"></span>
                </a>
            ))}
        </div>

        <!-- CTA Button -->
        <a href={whatsappUrl}
            class="premium-button inline-flex items-center gap-2 rounded-xl px-3 py-2 sm:px-4 text-sm font-semibold"
            aria-label="Cotizar por WhatsApp">
            <i class="fa-brands fa-whatsapp text-base"></i>
            <span class="hidden sm:inline">Cotizar ahora</span>
            <span class="sm:hidden">WhatsApp</span>
        </a>
    </div>
</nav>

<style>
    /* Nav link underline animation */
    .nav-link::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 1px;
        background: linear-gradient(90deg, #22d3ee, #67e8f9);
        border-radius: 99px;
        transition: width 280ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    .nav-link:hover::after {
        width: 100%;
    }

    /* Scrolled state: stronger glass */
    #main-navbar[data-scrolled] .navbar-inner {
        background: rgba(5,8,22,0.88) !important;
        box-shadow: 0 12px 48px rgba(0,0,0,0.45), 0 0 0 1px rgba(34,211,238,0.08), inset 0 1px 0 rgba(255,255,255,0.05) !important;
    }
</style>