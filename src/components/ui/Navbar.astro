---
import { navLinks, whatsappUrl } from '../../data/landing';
---

<nav class="fixed inset-x-0 top-0 z-50 px-4 pt-4 sm:px-6 animate-fade-in">
    <div class="premium-surface mx-auto flex max-w-7xl items-center justify-between rounded-full bg-[#050816]/75 px-4 py-3 animate-pulse-glow">
        <a href="#home" class="flex items-center gap-3 text-white">
            <span class="flex h-10 w-10 items-center justify-center rounded-full border border-cyan-400/30 bg-cyan-400/10 text-sm font-semibold text-cyan-200 shadow-[0_0_24px_rgba(34,211,238,0.18)]">
                MW
            </span>
            <span class="text-sm font-semibold tracking-[0.24em] uppercase sm:text-base">Marco Webs Studio</span>
        </a>

        <div class="hidden items-center gap-8 text-sm text-slate-200/80 md:flex">
            {navLinks.map((item) => (
                <a class="transition hover:text-white" href={item.href}>{item.label}</a>
            ))}
        </div>

        <a
            href={whatsappUrl}
            class="premium-button inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold"
            aria-label="Cotizar por WhatsApp"
        >
            <i class="fa-brands fa-whatsapp text-base"></i>
            <span class="hidden sm:inline">Cotizar por WhatsApp</span>
            <span class="sm:hidden">WhatsApp</span>
        </a>
    </div>
</nav>