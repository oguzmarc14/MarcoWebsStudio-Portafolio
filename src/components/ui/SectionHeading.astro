---
interface Props {
    eyebrow: string;
    title: string;
    description?: string;
    titleGradient?: boolean;
}

const { eyebrow, title, description, titleGradient = false } = Astro.props as Props;
---

<div class="mb-16 space-y-5" data-reveal style="--reveal-delay: 0ms;">

    <!-- Eyebrow -->
    <div class="flex items-center gap-3">
        <div class="h-px w-8 rounded-full" style="background: linear-gradient(90deg, transparent, rgba(34,211,238,0.6));"></div>
        <p class="premium-chip inline-flex rounded-full px-4 py-2 text-xs font-bold uppercase tracking-[0.3em] text-cyan-200/90">
            {eyebrow}
        </p>
        <div class="h-px flex-1 rounded-full max-w-[3rem]" style="background: linear-gradient(90deg, rgba(34,211,238,0.3), transparent);"></div>
    </div>

    <!-- Title -->
    <h2 class:list={[
        'text-3xl font-bold leading-tight tracking-tight sm:text-4xl lg:text-5xl',
        titleGradient ? 'gradient-text-subtle' : 'text-white glow-text-subtle'
    ]}>
        {title}
    </h2>

    <!-- Description -->
    {description && (
        <p class="max-w-xl text-base leading-7 text-slate-400">{description}</p>
    )}
</div>