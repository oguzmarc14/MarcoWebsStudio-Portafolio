---
interface Props {
	eyebrow: string;
	title: string;
	description?: string;
}

const { eyebrow, title, description } = Astro.props as Props;
---

<div class="mb-12 max-w-2xl space-y-4">
	<p class="text-sm font-semibold uppercase tracking-[0.28em] text-cyan-200/80">{eyebrow}</p>
	<h2 class="text-3xl font-semibold text-white sm:text-4xl">{title}</h2>
	{description && <p class="text-slate-300">{description}</p>}
</div>