---
import Boton from "./Boton.astro";

interface Props {
  imagen: string;
  altImagen: string;
}

const { imagen, altImagen } = Astro.props as Props;
---

<header
  class:list={[
    "bg-linear-to-r",
    "from-[#243b55]",
    "via-[#1f2f45]",
    "to-[#141e30]",
    "relative",
    "overflow-hidden",
    "h-screen",
  ]}
>
  <div class:list={["absolute", "inset-0", "w-full", "h-full"]}>
    <img src={imagen} alt={altImagen} class="w-full h-auto object-cover" />
    {/* Gradiente oscuro en la parte inferior */}
    <div class="absolute inset-0 w-full h-full pointer-events-none">
      <div class="absolute bottom-0 left-0 w-full h-[40%] bg-gradient-to-t from-black via-black/90 to-transparent"></div>
    </div>
  </div>
  <div
    class:list={[
      "relative",
      "z-10",
      "flex",
      "h-full",
      "w-full",
      "flex",
      "flex-col",
      "ml-10",
      "justify-center",
    ]}
  >
    <h1 class:list={["text-white", "relative", "text-8xl", "font-family"]}>
      Marco<br />Webs Studio
    </h1>
    <h2 class:list={["text-blue-300/60", "ml-1", "font-family", "text-3xl", "w-3/7"]}>
      Tu negocio necesita una web que genere clientes, no solo que se vea bonita
    </h2>
    <slot>
      <div class:list={["flex", "gap-2"]}>
        <Boton textBoton1="Cotizar Mi Pagina Web" href="#home" botonPrincipal />
        <Boton textBoton1="Proyectos" href="#hom" botonPrincipal={false} />
      </div>
    <div class:list={["flex", "items-center", "gap-4", "mt-10", "ml-2"]}>
        <a href=""><i class="fa-brands fa-instagram text-white text-4xl hover:scale-110 duration-300"></i></a>
        <a href=""><i class="fa-brands fa-facebook text-white text-3xl hover:scale-110 duration-300"></i></a>
        <a href=""><i class="fa-brands fa-tiktok text-white text-3xl hover:scale-110 duration-300"></i></a>
    </div>
    </slot>
  </div>
</header>
